    "pipeSize": { "label": "Pipe Size", "placeholder": "e.g., DN 150", 
                  "defaultValue": "DN 150"
                },
    "pipeSchedule": { "label": "Pipe Schedule", "placeholder": "e.g., SCH 40", "defaultValue": "SCH 40" },
    "nominalPressure": { "label": "Nominal Pressure", "placeholder": "e.g., 1.6 MPa", 
                         "defaultValue": "1.6 MPa",
                          "dropdown": true,
                          "options": [
                                        "1.6 MPa",
                                        "2.5 MPa"
                                      ] 
                       },
    "electrode": { "label": "Electrode", "placeholder": "e.g., SS316L", "defaultValue": "SS316L" },
