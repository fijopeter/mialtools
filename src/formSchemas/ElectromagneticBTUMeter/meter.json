      "label": "Measuring Technology",
      "placeholder": "e.g., Electromagnetic",
      "defaultValue": "Electromagnetic",
      "disabled": true
    },
    "meterTag": {
      "label": "Meter Tag",
      "placeholder": "e.g., BTU-01 (UMM AL QUWAIN SPECIALIST DENTAL CENTER)"
    },
    "communicationInterface": {
      "label": "Communication Interface",
      "placeholder": "e.g., Modbus RS-485",
      "defaultValue": "Modbus RS-485"
    },
    "address": { "label": "Address", "placeholder": "e.g., 01" },
    "baudRate": { "label": "Baud Rate", "placeholder": "e.g., 9600", "defaultValue": "9600" },
    "parity": { "label": "Parity", "placeholder": "e.g., None", "defaultValue": "None" },
    "energyRateUnit": { "label": "Energy Rate", "placeholder": "e.g., kW", "defaultValue": "kW" },
    "energyTotalUnit": { "label": "Energy Total", "placeholder": "e.g., kWh × 1000", "defaultValue": "kWh × 1000" },
    "flowRateUnit": { "label": "Flow Rate", "placeholder": "e.g., L/s", "defaultValue": "L/s" },
    "flowTotalUnit": { "label": "Flow Total", "placeholder": "e.g., Litres × 1000", "defaultValue": "Litres × 1000" },
    "temperatureUnit": { "label": "Temperature", "placeholder": "e.g., °C", "defaultValue": "°C" },
    "calibratedBy": {
      "label": "Calibrated By",
      "placeholder": "Enter technician name",
      "defaultValue": "JERIN ZACHARIA"
