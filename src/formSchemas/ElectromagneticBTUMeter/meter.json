        "protection",
        "pipeType",
        "linerMaterial",
        "measuringTube",
        "flowTubeTemperature",
        "flangeType",
        "customerKFactor",
        "analogRange"
      ]
    },
    {
      "title": "BTU METER INFORMATION",
      "fields": [
        "model",
        "serialNo",
        "measuringTechnology",
        "meterTag",
        "communicationInterface",
        "address",
        "baudRate",
        "parity"
      ]
    },
    {
      "title": "ENGINEERING UNITS",
      "fields": [
        "energyRateUnit",
        "energyTotalUnit",
        "flowRateUnit",
        "flowTotalUnit",
        "temperatureUnit"
      ]
    },
    {
      "title": "CALIBRATION SIGN-OFF",
      "fields": ["calibratedBy", "date"]
    }
