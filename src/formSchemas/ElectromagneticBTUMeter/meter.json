      "label": "Temperature Sensor",
      "placeholder": "e.g., Immersion Type – PT1000",
      "defaultValue": "Immersion Type – PT1000"
    },
    "temperatureSensorRange": {
      "label": "Temperature Sensor Range",
      "placeholder": "e.g., -30 °C to +200 °C",
      "defaultValue": "-30 °C to +200 °C"
    },
    "powerSupply": { "label": "Power Supply", "placeholder": "e.g., 24 VDC", "defaultValue": "24 VDC", "disabled": true },
